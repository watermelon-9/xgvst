# API provider switch: workers | alltick | sina | tencent | mock
# 默认 workers；alltick/sina/tencent 目前为占位实现，失败会回退 mock（若 PUBLIC_API_FALLBACK_MOCK=true）
PUBLIC_API_PROVIDER=workers

# Workers API endpoint（优先）
PUBLIC_WORKER_API_URL=

# 兼容旧网关 endpoint（仅在未设置 PUBLIC_WORKER_API_URL 时使用）
PUBLIC_API_URL=

# 请求失败时是否回退 mock 数据（默认 true）
PUBLIC_API_FALLBACK_MOCK=true
