# Root-level env examples (copy to .env.local / CI variables as needed)

# Optional: custom API URL for deployment scripts / legacy references
API_URL=

# Optional: Cloudflare Pages project/domain hint used by deploy scripts
CF_PAGES=

# --- Web app public vars (apps/web) ---
# API provider switch: workers | alltick | sina | tencent | mock
# Default is workers; fallback is OFF by default to avoid masking real worker integration issues.
PUBLIC_API_PROVIDER=workers

# Preferred workers gateway endpoint (highest priority)
PUBLIC_WORKER_API_URL=

# Legacy endpoint fallback when PUBLIC_WORKER_API_URL is empty
PUBLIC_API_URL=

# Whether to fallback to mock data on provider request failure (default false)
PUBLIC_API_FALLBACK_MOCK=false

# --- Workers runtime vars (wrangler vars/secrets) ---
# Optional CORS allow-list, comma-separated. Example:
# CORS_ALLOW_ORIGINS=https://xgvst.com,https://xgvst.pages.dev
# Default when empty: *
CORS_ALLOW_ORIGINS=
# KV quote:${symbol} snapshot TTL (seconds), default 300.
QUOTE_SNAPSHOT_TTL_SECONDS=300
# Access/JWT guard for user-scoped APIs (/api/self-selects*, /api/v2/self-selects*)
# 1=required(default), 0=disable for local quick debug.
ACCESS_AUTH_REQUIRED=1
# Trust Cloudflare Access injected identity header (cf-access-authenticated-user-email).
# Enable only when endpoint is behind Cloudflare Access.
ACCESS_TRUST_CF_HEADERS=0
# Optional strict JWT claims.
ACCESS_JWT_ISS=
ACCESS_JWT_AUD=
# Local simulation only (HS256). Put as Wrangler secret in real runtime.
ACCESS_JWT_HS256_SECRET=
# Debug-only: allow resync_ack to piggyback JSON immediateData (default OFF / strict mode).
# Set to 1 only for compatibility debugging.
QUOTE_DO_DEBUG_IMMEDIATE_DATA_JSON=0

# Source-provider credentials (do NOT commit plaintext values):
# Use Wrangler Secrets in each target environment:
#   wrangler secret put ALLTICK_TOKEN
#   wrangler secret put SINA_COOKIE
#   wrangler secret put EASTMONEY_TOKEN
#   wrangler secret put TENCENT_TOKEN
ALLTICK_TOKEN=
SINA_COOKIE=
EASTMONEY_TOKEN=
TENCENT_TOKEN=
